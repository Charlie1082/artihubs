# Artihubs production environment manifest (EG-TASK-0013)
# Template only — NO VALUES. Secrets are provisioned exclusively by charlie-nim
# via Vercel project settings (vercel env add <NAME> production). Never commit
# real values to any tracked file.
#
# Tier semantics:
#   REQUIRED-NOW    — production behavior is wrong or breaks on the next
#                     redeploy without it (env is snapshotted into a deployment
#                     at build time; the project env store is currently EMPTY,
#                     so the next redeploy loses everything the live deployment
#                     still carries).
#   LAUNCH-REQUIRED — must exist before public membership/auth/bot-protection
#                     surfaces are enabled.
#   OPTIONAL        — feature-conditional or hardening.
# Kind semantics:
#   SECRET — sensitive value; set only in Vercel env (charlie-nim/L3).
#   TOGGLE — non-secret behavior switch; value proposals below can be applied
#            by Engineering once approved (no secret handling involved).
#   CONFIG — non-secret configuration value.

########################################
# REQUIRED-NOW
########################################

# [SECRET] Anthropic key powering /api/v1/search Claude mode. Owner: charlie-nim.
# Accepted alternative name: CLAUDE_API_KEY (search handler checks both).
ANTHROPIC_API_KEY=

# [CONFIG] Supabase project URL used by intake/auth/admin/search-log utilities.
SUPABASE_URL=

# [SECRET] Supabase server-side key for /api/v1/intake writes and admin/audit
# paths. Accepted alternative name: SUPABASE_SECRET_KEY (newer key label).
SUPABASE_SERVICE_ROLE_KEY=

# [TOGGLE] Search behavior when Claude is unavailable.
# Proposed production value: degraded (HTTP 200 + fallbackRank + banner).
# strict = fail closed; use only for Claude-only dry tests.
SEARCH_FALLBACK_MODE=degraded

# [TOGGLE] Maker profile source for search ranking.
# Proposed production value: local until public_maker_profiles migration is
# reviewed, applied, and approved.
SEARCH_PROFILE_SOURCE=local

# [TOGGLE] Intake destination table.
# Proposed production value: public_intake (current prototype table). Switch to
# intake_submissions only after docs/deployment/migrations review.
INTAKE_TABLE=public_intake

# [TOGGLE] Rate limiting backend for public POST endpoints.
# Proposed production value: memory (best effort) until migration
# 008_rate_limit_buckets.sql is applied, then supabase.
RATE_LIMIT_MODE=memory

# [CONFIG] Comma-separated browser origins allowed to call public POST APIs.
# Same-host requests are allowed automatically.
ALLOWED_ORIGINS=https://artihubs.com,https://www.artihubs.com

########################################
# LAUNCH-REQUIRED (before public auth/membership/bot protection)
########################################

# [CONFIG] Supabase public browser key for auth flows.
# Accepted alternative name: SUPABASE_PUBLISHABLE_KEY (newer key label).
SUPABASE_ANON_KEY=

# [TOGGLE] Public signup/login API gate.
# Proposed production value: false until non-production Auth, SMTP, RLS, and
# /api/v1/me validation pass.
AUTH_PUBLIC_AUTH_ENABLED=false

# [SECRET] Cloudflare Turnstile server secret for bot verification.
TURNSTILE_SECRET_KEY=

# [TOGGLE] Enforce Turnstile verification on public forms.
# Proposed production value: false until deployed forms submit a verified
# client token, then true.
TURNSTILE_REQUIRED=false

# [CONFIG] Cloudflare Turnstile public site key (browser-side meta tag value;
# not read by api/ but paired with TURNSTILE_SECRET_KEY).
TURNSTILE_SITE_KEY=

# [SECRET] HMAC secret for hashing IP metadata in audit events (>=32 random
# chars). Recommended at launch so audit trails never store raw IPs.
AUDIT_IP_HASH_SECRET=

########################################
# OPTIONAL / FEATURE-CONDITIONAL
########################################

# [CONFIG] Comma-separated origins allowed to call Admin APIs. Leave empty
# unless the Admin Console is intentionally hosted on a separate trusted origin.
ADMIN_ALLOWED_ORIGINS=

# [TOGGLE] Search query logging (disabled until explicitly approved).
# Proposed production value: false.
SEARCH_QUERY_LOGGING_ENABLED=false

# [SECRET] Required only when SEARCH_QUERY_LOGGING_ENABLED=true (>=32 random
# chars; queries are stored hashed, never raw).
SEARCH_QUERY_HASH_SECRET=

########################################
# PLATFORM-PROVIDED (do not set manually)
########################################
# VERCEL_ENV  — injected by Vercel (production/preview/development)
# NODE_ENV    — injected by the runtime
#
# Script-only variables intentionally excluded from this production manifest:
# NON_PRODUCTION_VALIDATION, ARTIHUBS_SUPABASE_TARGET, ARTIHUBS_VALIDATION_*,
# ORBIT_GEOMETRY_*, CHROME_BIN/GOOGLE_CHROME_BIN (local tooling only; the
# validation set must never be set in production).
