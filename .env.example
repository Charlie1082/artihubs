SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-vercel-environment-secret
# Alternative if your Supabase project exposes a newer server-side secret key name:
# SUPABASE_SECRET_KEY=replace-with-vercel-environment-secret
ANTHROPIC_API_KEY=replace-with-vercel-environment-secret
# Alternative key name accepted by /api/search:
# CLAUDE_API_KEY=replace-with-vercel-environment-secret
