SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-public-anon-or-publishable-key
# Alternative if your Supabase project exposes a newer public key label:
# SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-public-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-vercel-environment-secret
# Alternative if your Supabase project exposes a newer server-side secret key name:
# SUPABASE_SECRET_KEY=replace-with-vercel-environment-secret
ANTHROPIC_API_KEY=replace-with-vercel-environment-secret
# Alternative key name accepted by /api/search:
# CLAUDE_API_KEY=replace-with-vercel-environment-secret
# Keep local until public_maker_profiles is migrated and approved.
SEARCH_PROFILE_SOURCE=local
# Production default. Use strict only for Claude-only dry tests.
SEARCH_FALLBACK_MODE=degraded
# Keep public_intake for the current prototype table. Switch to intake_submissions
# only after docs/deployment/migrations has been reviewed and applied.
INTAKE_TABLE=public_intake
# memory is best-effort only. supabase requires migration 008_rate_limit_buckets.sql.
RATE_LIMIT_MODE=memory
# Optional comma-separated browser origins allowed to call POST APIs.
# Same-host browser requests are allowed automatically.
ALLOWED_ORIGINS=https://artihubs.com,https://www.artihubs.com
# Optional comma-separated browser origins allowed to call Admin APIs.
# Leave empty unless Admin Console is intentionally hosted on a separate trusted origin.
ADMIN_ALLOWED_ORIGINS=
# Keep false until non-production Auth, SMTP, RLS, and /api/v1/me validation pass.
AUTH_PUBLIC_AUTH_ENABLED=false
# Live auth validation is blocked unless these are set only in a disposable
# non-production environment. Do not set these for production.
NON_PRODUCTION_VALIDATION=false
ARTIHUBS_SUPABASE_TARGET=development
# Optional only in an uncommitted non-production env file for validation scripts.
# ARTIHUBS_VALIDATION_EMAIL=disposable-validation@example.com
# ARTIHUBS_VALIDATION_PASSWORD=replace-with-disposable-nonproduction-password
# ARTIHUBS_VALIDATION_DISPLAY_NAME=Artihubs Nonproduction Test
# Optional. Search query logging is disabled until this is explicitly enabled.
SEARCH_QUERY_LOGGING_ENABLED=false
# Required only when SEARCH_QUERY_LOGGING_ENABLED=true. Use at least 32 random characters.
SEARCH_QUERY_HASH_SECRET=replace-with-vercel-environment-secret
TURNSTILE_SECRET_KEY=replace-with-vercel-environment-secret
# Set to true only after deployed public forms submit a verified Turnstile client token.
TURNSTILE_REQUIRED=false
# Public browser key. Add it to the turnstile-site-key meta tag on pages with public forms.
TURNSTILE_SITE_KEY=replace-with-cloudflare-public-site-key
# Optional. Enables HMAC hashing for audit event IP metadata. Use at least 32 random characters.
AUDIT_IP_HASH_SECRET=replace-with-vercel-environment-secret
